{
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/strict"
  ],
  "ignorePatterns": [
    "node_modules/",
    ".next/"
  ],
  "rules": {
    "eqeqeq": ["error", "always"],
    "no-console": ["warn", { "allow": ["error", "warn"] }],
    "no-var": "error",
    "curly": "error"
  }
}